{
  "rewrites": [
    {
      "source": "/aistudent/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/Retention-AI/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/Retention-AI/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/Retention-AI",
      "destination": "/index.html"
    },
    {
      "source": "/aistudent/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/aistudent",
      "destination": "/index.html"
    }
  ]
}
